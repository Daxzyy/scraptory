{
  "routes": [
    {
      "src": "/view/(?<fileName>.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(whatsapp|facebookexternalhit|twitterbot|slackbot|linkedinbot|discordbot|telegrambot).*"
        }
      ],
      "dest": "/api/og?fileName=$fileName"
    },
    { "src": "/raw/(.*)", "dest": "/scripts/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
